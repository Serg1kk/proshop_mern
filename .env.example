# Copy this file to `.env` in the repo root and fill in the values.
# The real `.env` is gitignored — do not commit it.

# `development` | `production` — controls morgan logging and the SPA static handler in server.js
NODE_ENV=development

# Backend HTTP port. Default 5001 locally (5000 often collides on macOS / Control Center).
# The frontend proxy in frontend/package.json must match this port.
PORT=5001

# MongoDB connection string.
#   - Local Docker: mongodb://localhost:27017/proshop
#   - Atlas:        mongodb+srv://<user>:<pass>@<cluster>/proshop?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/proshop

# Secret used to sign JWTs. Any non-empty string works for local dev; rotate for real deployments.
JWT_SECRET=dev_secret_change_me

# PayPal REST client id. `sb` is PayPal's public sandbox value and is fine for local checkout.
# For production sandbox testing, create an app at https://developer.paypal.com/ and paste the client id.
PAYPAL_CLIENT_ID=sb
